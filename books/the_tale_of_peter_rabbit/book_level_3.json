        "language": "en",
        "model": "hexgrad/Kokoro-82M"
      }
    },
    {
      "page_number": 3,
      "content": "Peter finds a way to squeeze under a big wooden gate. He enters the wonderful garden full of green things.",
      "source_page_number": 3,
      "image": {
        "path": "images/page_003.jpg",
        "filename": "page_003.jpg",
        "content_type": "image/jpeg"
      },
