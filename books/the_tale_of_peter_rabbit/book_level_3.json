        "content_type": "audio/mpeg",
        "provider": "kokoro",
        "language": "en",
        "model": "hexgrad/Kokoro-82M"
      }
    },
    {
      "page_number": 4,
      "content": "He eats many carrots and tasty red radishes for lunch. This food is very yummy, but it was not meant for him.",
      "source_page_number": 4,
      "image": {
        "path": "images/page_004.jpg",
        "filename": "page_004.jpg",
        "content_type": "image/jpeg"
      },
      "audio": {
