        "language": "en",
        "model": "hexgrad/Kokoro-82M"
      }
    },
    {
      "page_number": 7,
      "content": "Leo reminds us, we learned many emotions today: happy, sad, angry, scared, and surprised. Remember that finding joy, even during unexpected moments, makes life a truly delightful adventure for all.",
      "source_page_number": 7,
      "image": {
        "path": "images/page_007.jpg",
        "filename": "page_007.jpg",
        "content_type": "image/jpeg"
      },
      "audio": {
        "path": "voices/book_level_5/page_007.mp3",
        "filename": "page_007.mp3",
