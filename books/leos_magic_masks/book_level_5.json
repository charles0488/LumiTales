        "content_type": "audio/mpeg",
        "provider": "kokoro",
        "language": "en",
        "model": "hexgrad/Kokoro-82M"
      }
    },
    {
      "page_number": 6,
      "content": "Surprise! The Orange Mask shows us that this excited feeling arrives when something wonderful and unexpected happens. What a joyful surprise this celebration is!",
      "source_page_number": 6,
      "image": {
        "path": "images/page_006.jpg",
        "filename": "page_006.jpg",
        "content_type": "image/jpeg"
      },
      "audio": {
