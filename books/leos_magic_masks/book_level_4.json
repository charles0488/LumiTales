        "language": "en",
        "model": "hexgrad/Kokoro-82M"
      }
    },
    {
      "page_number": 6,
      "content": "What happens when something amazing and unexpected occurs? That's the time for The Orange Mask: Surprised! It shows us pure joy, just like finding a sudden party!",
      "source_page_number": 6,
      "image": {
        "path": "images/page_006.jpg",
        "filename": "page_006.jpg",
        "content_type": "image/jpeg"
      },
      "audio": {
