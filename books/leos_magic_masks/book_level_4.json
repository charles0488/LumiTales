      }
    },
    {
      "page_number": 2,
      "content": "When Leo feels sunny and playful, he might wear the Yellow Mask: Happy! This delightful mask shows us that happiness comes from spending time with friends or seeing beautiful sunshine.",
      "source_page_number": 2,
      "image": {
        "path": "images/page_002.jpg",
        "filename": "page_002.jpg",
        "content_type": "image/jpeg"
      },
      "audio": {
