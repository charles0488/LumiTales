{
  "title": "The Tale of Squirrel Nutkin",
  "pages": [
    {
      "page_number": 0,
      "content": "This book tells the story of a bright squirrel named Nutkin. He is featured in this lovely tale written by Beatrix Potter. Get ready to learn about his adventures!",
      "source_page_number": 0,
      "image": {
        "path": "images/page_000.jpg",
        "filename": "page_000.jpg",
        "content_type": "image/jpeg"
      },
