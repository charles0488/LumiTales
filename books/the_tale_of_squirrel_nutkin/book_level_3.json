      "page_number": 0,
      "content": "This book is called The Tale of Squirrel Nutkin. Beatrix Potter wrote this story about a little cartoon squirrel.",
      "source_page_number": 0,
      "image": {
        "path": "images/page_000.jpg",
        "filename": "page_000.jpg",
        "content_type": "image/jpeg"
      },
