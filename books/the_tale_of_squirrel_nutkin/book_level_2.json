    {
      "page_number": 1,
      "content": "Nutkin lived with his mamma and three sisters in a tree. They were by the big lake.",
      "source_page_number": 1,
      "image": {
        "path": "images/page_001.jpg",
        "filename": "page_001.jpg",
        "content_type": "image/jpeg"
      },
      "audio": {
